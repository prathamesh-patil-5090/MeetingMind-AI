# Local NestJS API
PORT=3847
DATA_DIR=./data
MEETINGS_DIR=./meetings

# Database (SQLite)
DATABASE_URL="file:./prisma/meetingmind.db"

# AI Provider: groq | openrouter | openai | ollama | mock
# Default: Groq Console (Whisper STT + LLM summarize/chat)
AI_PROVIDER=groq

# Multiple Groq keys (comma-separated) — segregated by request lane
GROQ_API_KEYS=
# Optional lane → key index overrides (0-based into GROQ_API_KEYS)
# Defaults with 5 keys: whisper=0 chat=1 extract=2 vision=3 general=4
# GROQ_LANE_WHISPER=0
# GROQ_LANE_CHAT=1
# GROQ_LANE_EXTRACT=2
# GROQ_LANE_VISION=3
# GROQ_LANE_GENERAL=4

GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=qwen/qwen3.6-27b
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Screenshot sampling for OCR / vision (spread across whole meeting)
# For ~2h meetings: 18 frames ⇒ roughly one every ~6–7 minutes
SCREENSHOT_INTERVAL_SEC=60
SCREENSHOT_MAX_FRAMES=18

# Long-meeting LLM windows (chars). Chunks overlap slightly when summarizing/extracting.
LONG_MEETING_CHUNK_CHARS=10000

# Optional alternate providers
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct
OPENROUTER_VISION_MODEL=qwen/qwen2.5-vl-72b-instruct
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434
